# Copy this file to .env and fill in your own values. Never commit .env.

# MongoDB connection string (MongoDB Atlas or local mongodb://localhost:27017/skillbridge)
MONGO_URI=mongodb://localhost:27017/skillbridge

# Any long random string — used to sign JWT tokens
JWT_SECRET=change_this_to_a_long_random_string

# How long a login session stays valid
JWT_EXPIRES_IN=7d

# Port the API server runs on
PORT=5000

# Frontend URL, for CORS (Vite dev server default)
CLIENT_URL=http://localhost:5173
